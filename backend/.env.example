# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/course_select

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM API Keys (at least one required)
MIMO_API_KEY=change-me-in-production
MIMO_API_BASE_URL=change-me-in-production
MIMO_MODEL=change-me-in-production

# Optional: OpenAI / Claude fallback
OPENAI_API_KEY=change-me-in-production
CLAUDE_API_KEY=change-me-in-production

# Application
SECRET_KEY=change-me-in-production
DEBUG=true
LOG_LEVEL=info

# Session
SESSION_EXPIRE_SECONDS=86400
